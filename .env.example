POSTGRES_DB=puls
POSTGRES_USER=puls
# Zalecane: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_HEX_PASSWORD

# Publiczny adres wystawiony przez Pangolin, bez ukośnika na końcu.
APP_ORIGIN=https://puls.example.com
PULS_BIND=127.0.0.1
PULS_EDGE_NETWORK=puls-edge

# Wygeneruj dokładnie: openssl rand -base64 32
# Nie zmieniaj po połączeniu Google bez wcześniejszego odłączenia integracji.
TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64_KEY

# Wygeneruj: openssl rand -hex 32
BOOTSTRAP_TOKEN=CHANGE_ME_BOOTSTRAP_TOKEN_AT_LEAST_24_CHARS
SESSION_DAYS=30
LOG_LEVEL=info

# Po buildzie:
# docker compose run --rm app sh -lc 'cd /app/server && ./node_modules/.bin/web-push generate-vapid-keys'
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
WORKER_INTERVAL_MS=30000

# Opcjonalna integracja Google Calendar.
# Ustaw wszystkie trzy wartości razem. Pozostaw puste, aby wyłączyć integrację.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
